{
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
    	"rootDir": "."
	},
	"ts-node": {
		"transpileOnly": true,
		"files": true
	},
	"include": [
		"./scripts",
		"./test",
		"./typechain-types",
		"./hardhat.config.ts", 
		"utils/helper.ts"
	],
	"exclude": [
		"node_modules"
	]
}